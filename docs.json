{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Candidate Profile API",
  "colors": {
    "primary": "#2563EB",
    "light": "#60A5FA",
    "dark": "#1D4ED8"
  },
  "favicon": "/favicon.svg",
  "openapi": "/api-reference/openapi.json",
  "navigation": {
    "tabs": [
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "icon": "book-open",
            "pages": [
              "index",
              "api-reference/introduction"
            ]
          },
          {
            "group": "Authentication",
            "icon": "key",
            "pages": [
              "api-reference/authentication",
              "api-reference/endpoint/auth-token"
            ]
          },
          {
            "group": "Candidate",
            "icon": "user",
            "pages": [
              "api-reference/endpoint/candidate"
            ]
          },
          {
            "group": "Experience",
            "icon": "briefcase",
            "pages": [
              "api-reference/endpoint/experience-list",
              "api-reference/endpoint/experience-get"
            ]
          },
          {
            "group": "Projects",
            "icon": "folder-open",
            "pages": [
              "api-reference/endpoint/projects-list",
              "api-reference/endpoint/project-get"
            ]
          },
          {
            "group": "Resume",
            "icon": "file-text",
            "pages": [
              "api-reference/endpoint/resume"
            ]
          },
          {
            "group": "Contact",
            "icon": "terminal",
            "pages": [
              "api-reference/endpoint/availability",
              "api-reference/endpoint/contact"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/favicon.svg",
    "dark": "/favicon.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/jonahanderson"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Portfolio Site",
      "href": "https://jonahanderson.me"
    }
  },
  "integrations": {
    "telemetry": {
      "enabled": false
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "website": "https://jonahanderson.me",
      "github": "https://github.com/jonahanderson"
    }
  }
}
