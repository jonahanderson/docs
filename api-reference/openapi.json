{
  "info": {
    "name": "Candidate Profile API",
    "_postman_id": "e6ef4d7f-a88f-4c48-8676-1c541c0a1f47",
    "description": "Collection for local and production testing of the Candidate Profile API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    }
  ],
  "item": [
    {
      "name": "Get Candidate",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/candidate",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "candidate"
          ]
        }
      }
    },
    {
      "name": "List Experience",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/experience",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "experience"
          ]
        }
      }
    },
    {
      "name": "List Current Experience",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/experience?current=true",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "experience"
          ],
          "query": [
            {
              "key": "current",
              "value": "true"
            }
          ]
        }
      }
    },
    {
      "name": "Get Experience By Id",
      "request": {
        "method": "GET",
        "header": [],
