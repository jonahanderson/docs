    {
      "name": "Create Contact Request",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Taylor Recruiter\",\n  \"email\": \"taylor@example.com\",\n  \"company\": \"Acme Corp\",\n  \"message\": \"Would love to connect about an integrations leadership role.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/contact",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "contact"
          ]
        }
      }
