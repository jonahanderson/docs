      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/resume?format=json",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "resume"
          ],
          "query": [
            {
              "key": "format",
              "value": "json"
            }
          ]
        }
      }
    },
    {
      "name": "Get Resume PDF Link",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/resume?format=pdf",
