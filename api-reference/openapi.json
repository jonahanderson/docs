          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "experience",
            "exp_dat"
          ]
        }
      }
    },
    {
      "name": "List Projects",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/projects",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "projects"
          ]
        }
      }
    },
    {
      "name": "Get Project By Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/projects/proj_001",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "projects",
            "proj_001"
          ]
        }
      }
    },
    {
      "name": "Get Availability",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/availability",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "availability"
          ]
        }
      }
